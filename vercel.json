{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/optimize",
      "dest": "api/optimize.js"
    },
    {
      "src": "/api/pixel",
      "dest": "api/pixel.js"
    },
    {
      "src": "/api/track-event",
      "dest": "api/track-event.js"
    }
  ]
}